DirectoryIndex index.php login.php
Options -Indexes

<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

<FilesMatch "\.(css|js|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
</FilesMatch>

AddType text/css .css
AddType application/javascript .js
